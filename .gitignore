# Local .terraform directories
**/.terraform/*

# .tfstate files (may contain secrets — never commit)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Variable files that may hold secrets / personal values (IP, etc.)
*.auto.tfvars
terraform.tfvars

# CLI config / plan output
.terraformrc
terraform.rc
*.tfplan

# Lock file is intentionally committed:
# .terraform.lock.hcl
